<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>My Resume</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    body {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 30px;
    }

    .resume {
        width: 100%;
        max-width: 900px;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(15px);
        border-radius: 20px;
        overflow: hidden;
        color: #fff;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .header {
        display: flex;
        align-items: center;
        padding: 30px;
        background: rgba(0,0,0,0.2);
    }

    .header img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 4px solid #fff;
        margin-right: 25px;
    }

    .header h1 {
        font-size: 32px;
    }

    .header p {
        opacity: 0.9;
    }

    .content {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 30px;
        padding: 30px;
    }

    .left, .right {
        background: rgba(255,255,255,0.1);
        padding: 20px;
        border-radius: 15px;
    }

    h2 {
        margin-bottom: 15px;
        border-bottom: 2px solid #fff;
        display: inline-block;
        padding-bottom: 5px;
    }

    ul {
        list-style: none;
    }

    ul li {
        margin-bottom: 10px;
    }

    .skill span {
        display: block;
        height: 8px;
        background: rgba(255,255,255,0.3);
        border-radius: 10px;
        margin-top: 5px;
        overflow: hidden;
    }

    .skill span::after {
        content: "";
        display: block;
        height: 100%;
        width: 80%;
        background: #00ffd5;
        border-radius: 10px;
    }

    .footer {
        text-align: center;
        padding: 15px;
        background: rgba(0,0,0,0.3);
        font-size: 14px;
    }

    @media(max-width:768px) {
        .content {
            grid-template-columns: 1fr;
        }
    }
</style>
</head>

<body>

<div class="resume">

    <div class="header">
        <img src="data:image/jpeg;base64," 
      alt="Profile Photo">
        <div>
            <h1>Pavan Suryavanshi</h1>
            <p>Web Developer | Designer</p>
        </div>
    </div>

    <div class="content">
        <div class="left">
            <h2>Contact</h2>
            <ul>
                <li>📧 Pavans6350@gmail.com</li>
                <li>📱 +91 635055817*9</li>
                <li>📍 Mandsaur, Madhya Pradesh, India, 458669</li>
            </ul>

            <h2 style="margin-top:20px;">Skills</h2>
            <div class="skill">HTML<span></span></div>
            <div class="skill">CSS<span></span></div>
            <div class="skill">JavaScript<span></span></div>
        </div>

        <div class="right">
            <h2>About Me</h2>
            <p>
                I am a creative and passionate web developer focused on building
                beautiful and functional websites.
            </p>

            <h2 style="margin-top:20px;">Education</h2>
            <p><b>Bachelor Of Computer Applications</b></p>
            <p>Mandsaur University (2024 - 2027)</p>

            <h2 style="margin-top:20px;">Projects</h2>
            <ul>
                <li>✔ Portfolio Website</li>
                <li>✔ Resume Website</li>
                <li>✔ Landing Pages</li>
            </ul>
        </div>
    </div>

    <div class="footer">
        © 2026 Pavan Suryavanshi | All Rights Reserved
    </div>

</div>

</body>
</html>
